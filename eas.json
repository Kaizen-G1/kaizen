{
  "build": {
    "development": {
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "$API_URL_DEVELOPMENT",
        "EXPO_PUBLIC_DEBUG_MODE": "$DEBUG_MODE_DEVELOPMENT"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "gradleCommand": ":app:assembleRelease"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "$API_URL_PRODUCTION",
        "EXPO_PUBLIC_DEBUG_MODE": "$DEBUG_MODE_PRODUCTION"
      }
    }
  }
}
