{
  "expo": {
    "name": "kaizen",
    "slug": "kaizen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gbc.kaizen",
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleLocalizations": ["en"]
      }
    },
    "android": {
      "package": "com.gbc.kaizen",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "**/*",
      "./assets/fonts/*"
    ],
    "extra": {
      "eas": {
        "projectId": "494f071b-6f58-4f34-9d01-897d7a12af2e"
      }
    },
    "owner": "kaizen-app",
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "pk_test_51R0lR8H8cqL7ypGhRQPKAMDcae5QQLc4qNbLM3UV9GAmbq8aj9N6urpZnOu8DNEdgZJBTjVDYBRaUIf3D9R6Dh5U00hHzWkmrz",
          "enableGooglePay": false
        }
      ]
    ]
  }
}
